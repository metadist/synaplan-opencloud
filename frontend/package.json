{
  "name": "synaplan-opencloud",
  "version": "0.0.0",
  "private": true,
  "description": "Synaplan integration for OpenCloud",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:w": "vite build --watch --mode development",
    "check:types": "vue-tsc --noEmit",
    "lint": "eslint 'src/**/*.{js,ts,vue}' --color",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "test:unit": "NODE_OPTIONS=--unhandled-rejections=throw vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@opencloud-eu/design-system": "^6.1.0",
    "@opencloud-eu/eslint-config": "^6.1.0",
    "@opencloud-eu/extension-sdk": "^6.1.0",
    "@opencloud-eu/prettier-config": "^6.1.0",
    "@opencloud-eu/tsconfig": "^6.1.0",
    "@opencloud-eu/web-client": "^6.1.0",
    "@opencloud-eu/web-pkg": "^6.1.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "24.12.0",
    "@vue/compiler-dom": "^3.5.30",
    "@vue/server-renderer": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "eslint": "10.0.3",
    "happy-dom": "^20.0.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.3",
    "uuid": "^13.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.2.1",
    "vue": "^3.4.21",
    "vue-tsc": "3.2.5",
    "vue3-gettext": "^4.0.0-beta.1",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "overrides": {
      "@module-federation/vite": "1.14.1"
    }
  }
}
